# Production Environment Variables
# Database
DATABASE_URL="postgresql://user:password@host:5432/smart_facebook_publisher"
DIRECT_URL="postgresql://user:password@host:5432/smart_facebook_publisher"

# Facebook/Meta API
FACEBOOK_APP_ID="YOUR_FACEBOOK_APP_ID"
FACEBOOK_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"
FACEBOOK_REDIRECT_URI="https://your-domain.com/api/auth/facebook/callback"

# OpenAI
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Redis (for job queue)
REDIS_URL="redis://user:password@host:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Application
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
